# Agent identity and behavior.
AGENT_NAME="Vaulted Slack Agent"
AGENT_DESCRIPTION="A custom Slack agent that routes outbound API calls through Agent Vault."
AGENT_MISSION="Help the team turn Slack requests into useful answers and actions using only the tools wired into this template."
AGENT_AUDIENCE="the Slack workspace where this agent is installed"
AGENT_TONE="practical, concise, and direct"
AGENT_MODEL=claude-sonnet-4-6
AGENT_MCP_SERVER_NAME=agent_tools
AGENT_EXTRA_INSTRUCTIONS=

# Optional: comma- or whitespace-separated Slack user emails allowed to use the
# bot. If unset, every Slack user in the installed workspace can use it.
AGENT_ALLOWLIST=

# Claude Agent SDK credential. In production, prefer an Agent Vault placeholder.
ANTHROPIC_API_KEY=__anthropic_api_key__

# Required only when running as a Slack bot. In production, prefer Agent Vault
# placeholders and configure Slack service rules in Agent Vault.
SLACK_BOT_TOKEN=__slack_bot_token__
SLACK_APP_TOKEN=__slack_app_token__

# Example read-only API tool. Replace this with your agent's real integrations.
# Configure the upstream host as a service in Agent Vault when it needs auth.
EXAMPLE_API_BASE_URL=
EXAMPLE_API_USER_AGENT=agent-vault-slack-template

# Required in production when running through Agent Vault.
AGENT_VAULT_ADDR=
AGENT_VAULT_TOKEN=
AGENT_VAULT_VAULT=

# Used by hosted web services.
PORT=3000
